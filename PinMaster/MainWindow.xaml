<Window x:Class="PinMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:PinMaster.Models"
        Title="Pin Master"
        Width="560"
        Height="660"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        ShowInTaskbar="False"
        Deactivated="Window_Deactivated"
        IsVisibleChanged="Window_IsVisibleChanged"
        SourceInitialized="Window_SourceInitialized">
    <Border x:Name="Shell"
            Background="{DynamicResource WindowBrush}"
            BorderBrush="{DynamicResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.24" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="2,0,2,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="34"
                        Height="34"
                        CornerRadius="8"
                        Background="{DynamicResource AccentSoftBrush}"
                        VerticalAlignment="Center">
                    <TextBlock Text="&#xE718;"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Pin Master"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Lightweight always-on-top control for Windows"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12" />
                    <TextBlock Text="Runs quietly in the background - reopen from the system tray"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Button Grid.Column="2"
                        Width="36"
                        Height="36"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Close"
                        Click="CloseButton_Click">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border CornerRadius="9"
                        Background="{DynamicResource PanelBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        Height="44">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="14"
                                   Margin="14,0,0,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Search windows"
                                   Grid.Column="1"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextBrush}"
                                 CaretBrush="{DynamicResource AccentBrush}"
                                 Margin="8,0,12,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="15"
                                 TextChanged="SearchBox_TextChanged" />
                    </Grid>
                </Border>

                <Button Grid.Column="1"
                        Width="42"
                        Height="42"
                        Margin="10,0,0,0"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Refresh"
                        Click="RefreshButton_Click">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                </Button>
            </Grid>

            <Grid Grid.Row="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="WindowList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:WindowInfo}">
                                <Border x:Name="ItemShell"
                                        Margin="0,0,0,8"
                                        Padding="0"
                                        CornerRadius="8"
                                        Background="{DynamicResource CardBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <Grid MinHeight="58">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="PinnedStripe"
                                                Width="4"
                                                CornerRadius="8,0,0,8"
                                                Background="Transparent" />

                                        <Border Grid.Column="1"
                                                Width="30"
                                                Height="30"
                                                CornerRadius="7"
                                                Background="{DynamicResource SubtlePanelBrush}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                            <Image Width="18"
                                                   Height="18"
                                                   Source="{Binding Icon}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="2"
                                                    Margin="8,0,12,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayTitle}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ProcessName}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,12,0">
                                            <TextBlock x:Name="PinnedLabel"
                                                       Text="Pinned"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"
                                                       Visibility="Collapsed" />
                                            <ToggleButton Style="{StaticResource ToggleSwitchStyle}"
                                                          IsChecked="{Binding IsPinned, Mode=OneWay}"
                                                          Click="PinToggle_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                        <Setter TargetName="ItemShell" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                        <Setter TargetName="PinnedStripe" Property="Background" Value="{DynamicResource AccentBrush}" />
                                        <Setter TargetName="PinnedLabel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="&#xE8A5;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="28"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10" />
                    <TextBlock Text="No matching windows"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Try clearing search or refreshing the list"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Width="40"
                        Height="36"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Settings"
                        Click="SettingsButton_Click">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                </Button>

                <StackPanel Grid.Column="1"
                            Margin="12,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="Created by github.com/viraj-rgb - lightweight with minimal idle RAM"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Unpin All"
                        Style="{StaticResource PillButtonStyle}"
                        Click="UnpinAllButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
