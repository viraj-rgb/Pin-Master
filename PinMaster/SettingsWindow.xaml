<Window x:Class="PinMaster.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="380"
        Height="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized">
    <Border Background="{DynamicResource WindowBrush}"
            BorderBrush="{DynamicResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.24" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34"
                            Height="34"
                            CornerRadius="8"
                            Background="{DynamicResource AccentSoftBrush}">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Settings"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Startup and theme"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Width="36"
                        Height="36"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Close"
                        Click="CloseButton_Click">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Launch on startup" Foreground="{DynamicResource TextBrush}" FontSize="14" />
                        <TextBlock Text="Start Pin Master when you sign in" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                    </StackPanel>
                    <ToggleButton x:Name="StartupToggle"
                                  Grid.Column="1"
                                  Style="{StaticResource ToggleSwitchStyle}"
                                  Checked="StartupToggle_Changed"
                                  Unchecked="StartupToggle_Changed" />
                </Grid>

                <StackPanel>
                    <TextBlock Text="Theme" Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,0,0,8" />
                    <ComboBox x:Name="ThemeCombo"
                              Height="38"
                              SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="System" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <Button Grid.Row="2"
                    Content="Done"
                    HorizontalAlignment="Right"
                    Style="{StaticResource PillButtonStyle}"
                    Click="CloseButton_Click" />
        </Grid>
    </Border>
</Window>
